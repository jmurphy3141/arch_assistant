"""
OCI BOM Generator — main.py
============================
A FastAPI application that drives a conversational Bill of Materials agent for
Oracle Cloud Infrastructure.  The agent uses an OCI Generative AI model
(hosted in us-chicago-1) to parse free-form infrastructure descriptions,
identify billable OCI services, ask targeted clarifying questions, and produce
a validated, priced BOM that can be downloaded as an XLSX file.

Architecture overview
---------------------
  Browser  ──►  GET  /              Serves index.html (the chat UI)
  Browser  ──►  GET  /config        Returns region + available model list
  Browser  ──►  POST /chat          Conversational BOM agent endpoint
  Browser  ──►  POST /generate-xlsx Converts a finalised BOM to XLSX
  Admin    ──►  POST /refresh-data  Reloads price list, compute shapes, and service catalog
  Monitor  ──►  GET  /health        Unauthenticated liveness probe

Pricing data
------------
The agent is grounded in the official OCI price list fetched live from:
  https://apexapps.oracle.com/pls/apex/cetools/api/v1/products/
USD unit_cost is used for all pricing.  The price list is NOT loaded on startup;
call POST /refresh-data to populate it (and to reload it at any time).

On-demand caches (not loaded on startup)
-----------------------------------------
  oci_compute_shapes.json   — scraped from OCI Compute Shapes docs page
  oci_services_catalog.json — scraped from OCI home.htm (category + name only)

Trigger POST /refresh-data to load or reload all three caches.

Authentication
--------------
All routes (except /health, /login, /oauth2/callback, and /logout) are protected
by OCI Identity Domain OAuth 2.0 / OpenID Connect session-based authentication.

Required environment variables
-------------------------------
  OCI_COMPARTMENT_ID    OCI compartment OCID for GenAI API calls
  OIDC_CLIENT_ID        OCI Identity Domain confidential app client ID
  OIDC_CLIENT_SECRET    OCI Identity Domain confidential app client secret
  OIDC_AUTHORIZATION_ENDPOINT  OAuth authorization endpoint
  OIDC_TOKEN_ENDPOINT   OAuth token endpoint
  OIDC_USERINFO_ENDPOINT OAuth userinfo endpoint
  OIDC_REDIRECT_URI     OAuth callback URL registered in Identity Domain
  SESSION_SECRET        Session signing secret

Optional environment variables
-------------------------------
  OCI_REGION                OCI region            (default: us-chicago-1)
  OCI_MODEL_ID              Override default model (default: first in CHICAGO_MODELS)
  OIDC_LOGOUT_ENDPOINT      Identity Domain logout URL
  OIDC_SCOPE                OAuth scopes          (default: openid profile email)
  OIDC_REQUIRED_GROUP       Require membership in a specific Identity Domain group
  MAX_PRICING_CONTEXT_CHARS Max chars sent to LLM  (default: 128000)
  LOG_LEVEL                 Logging verbosity      (default: INFO)
  BOM_LOG_FILE              Log file path          (default: bom.log)

Running locally
---------------
  pip install fastapi uvicorn[standard] oci python-dotenv openpyxl itsdangerous
  uvicorn main:app --reload
"""

from fastapi import FastAPI, HTTPException, Depends, status, Request
from fastapi.responses import FileResponse, StreamingResponse, RedirectResponse, HTMLResponse
from pydantic import BaseModel
import oci
import os
import re
import logging
import io
import json
import urllib.request
import urllib.error
import urllib.parse
from pathlib import Path
from typing import Optional, Any
from dotenv import load_dotenv
from openpyxl import Workbook
from openpyxl.styles import Font, PatternFill, Alignment, Border, Side
from starlette.middleware.sessions import SessionMiddleware

load_dotenv()

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
logging.basicConfig(
    level=os.getenv("LOG_LEVEL", "INFO").upper(),
    format="%(asctime)s %(levelname)s %(name)s - %(message)s",
)
logger = logging.getLogger(__name__)

BASE_DIR      = Path(__file__).resolve().parent
LOG_FILE_PATH = BASE_DIR / os.getenv("BOM_LOG_FILE", "bom.log")

_root = logging.getLogger()
if not any(isinstance(h, logging.FileHandler) for h in _root.handlers):
    _fh = logging.FileHandler(LOG_FILE_PATH)
    _fh.setLevel(_root.level)
    _fh.setFormatter(logging.Formatter("%(asctime)s %(levelname)s %(name)s - %(message)s"))
    _root.addHandler(_fh)

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
OCI_REGION     = os.getenv("OCI_REGION", "us-chicago-1")
COMPARTMENT_ID = os.getenv("OCI_COMPARTMENT_ID")
OIDC_CLIENT_ID            = os.getenv("OIDC_CLIENT_ID")
OIDC_CLIENT_SECRET        = os.getenv("OIDC_CLIENT_SECRET")
OIDC_AUTHORIZATION_ENDPOINT = os.getenv("OIDC_AUTHORIZATION_ENDPOINT")
OIDC_TOKEN_ENDPOINT       = os.getenv("OIDC_TOKEN_ENDPOINT")
OIDC_USERINFO_ENDPOINT    = os.getenv("OIDC_USERINFO_ENDPOINT")
OIDC_REDIRECT_URI         = os.getenv("OIDC_REDIRECT_URI")
OIDC_LOGOUT_ENDPOINT      = os.getenv("OIDC_LOGOUT_ENDPOINT")
OIDC_SCOPE                = os.getenv("OIDC_SCOPE", "openid profile email")
OIDC_REQUIRED_GROUP       = os.getenv("OIDC_REQUIRED_GROUP")
SESSION_SECRET            = os.getenv("SESSION_SECRET")

MAX_PRICING_CONTEXT_CHARS = int(os.getenv("MAX_PRICING_CONTEXT_CHARS", "128000"))

OCI_PRICE_LIST_API_URL = "https://apexapps.oracle.com/pls/apex/cetools/api/v1/products/"

PRICING_CACHE_PATH  = BASE_DIR / "oci_price_list.txt"
SHAPES_CACHE_PATH   = BASE_DIR / "oci_compute_shapes.json"
SERVICES_CACHE_PATH = BASE_DIR / "oci_services_catalog.json"

OCI_SHAPES_DOC_URL   = "https://docs.oracle.com/en-us/iaas/Content/Compute/References/computeshapes.htm"
OCI_SERVICES_DOC_URL = "https://docs.oracle.com/en-us/iaas/Content/home.htm"

# ---------------------------------------------------------------------------
# Available OCI GenAI on-demand chat models in us-chicago-1
# ---------------------------------------------------------------------------
CHICAGO_MODELS: list[dict[str, str]] = [
    {"id": "xai.grok-4-1-fast-reasoning",                 "name": "xAI Grok 4.1 Fast Reasoning"},
    {"id": "meta.llama-4-maverick-17b-128e-instruct-fp8", "name": "Meta Llama 4 Maverick"},
    {"id": "meta.llama-4-scout-17b-16e-instruct",         "name": "Meta Llama 4 Scout"},
    {"id": "google.gemini-2.5-pro",                       "name": "Google Gemini 2.5 Pro"},
    {"id": "google.gemini-2.5-flash",                     "name": "Google Gemini 2.5 Flash"},
    {"id": "google.gemini-2.5-flash-lite",                "name": "Google Gemini 2.5 Flash-Lite"},
    {"id": "openai.gpt-oss-120b",                         "name": "OpenAI GPT-OSS 120B"},
    {"id": "openai.gpt-oss-20b",                          "name": "OpenAI GPT-OSS 20B"},
    {"id": "xai.grok-4",                                  "name": "xAI Grok 4"},
]

DEFAULT_MODEL_ID = os.getenv("OCI_MODEL_ID") or CHICAGO_MODELS[0]["id"]

# ---------------------------------------------------------------------------
# Module-level caches
# ---------------------------------------------------------------------------
_PRICING_TEXT_CACHE:  Optional[str]                       = None
_PRICING_TABLE_CACHE: Optional[dict[str, dict[str, Any]]] = None
_SHAPES_TEXT_CACHE:   Optional[str]                       = None
_SERVICES_TEXT_CACHE: Optional[str]                       = None

# ---------------------------------------------------------------------------
# FastAPI app
# ---------------------------------------------------------------------------
app      = FastAPI(title="OCI BOM Generator")
app.add_middleware(
    SessionMiddleware,
    secret_key=SESSION_SECRET or "change-me-session-secret",
    same_site="lax",
    https_only=OIDC_REDIRECT_URI.startswith("https://") if OIDC_REDIRECT_URI else False,
)


def _validate_settings() -> None:
    missing = [name for name, val in [
        ("OCI_COMPARTMENT_ID", COMPARTMENT_ID),
        ("OIDC_CLIENT_ID", OIDC_CLIENT_ID),
        ("OIDC_CLIENT_SECRET", OIDC_CLIENT_SECRET),
        ("OIDC_AUTHORIZATION_ENDPOINT", OIDC_AUTHORIZATION_ENDPOINT),
        ("OIDC_TOKEN_ENDPOINT", OIDC_TOKEN_ENDPOINT),
        ("OIDC_USERINFO_ENDPOINT", OIDC_USERINFO_ENDPOINT),
        ("OIDC_REDIRECT_URI", OIDC_REDIRECT_URI),
        ("SESSION_SECRET", SESSION_SECRET),
    ] if not val]
    if missing:
        raise RuntimeError(f"Missing required environment variables: {', '.join(missing)}")


_validate_settings()


def _oauth_post_form(url: str, data: dict[str, str]) -> dict[str, Any]:
    body = urllib.parse.urlencode(data).encode("utf-8")
    credentials = f"{OIDC_CLIENT_ID}:{OIDC_CLIENT_SECRET}".encode("utf-8")
    import base64
    basic = base64.b64encode(credentials).decode("ascii")
    req = urllib.request.Request(
        url,
        data=body,
        headers={
            "Content-Type": "application/x-www-form-urlencoded",
            "Authorization": f"Basic {basic}",
        },
        method="POST",
    )
    with urllib.request.urlopen(req, timeout=30) as resp:
        return json.loads(resp.read().decode("utf-8"))


def _oauth_get_json(url: str, access_token: str) -> dict[str, Any]:
    req = urllib.request.Request(
        url,
        headers={"Authorization": f"Bearer {access_token}"},
    )
    with urllib.request.urlopen(req, timeout=30) as resp:
        return json.loads(resp.read().decode("utf-8"))


def _build_authorize_url(state: str) -> str:
    params = {
        "client_id": OIDC_CLIENT_ID,
        "response_type": "code",
        "scope": OIDC_SCOPE,
        "redirect_uri": OIDC_REDIRECT_URI,
        "state": state,
    }
    return f"{OIDC_AUTHORIZATION_ENDPOINT}?{urllib.parse.urlencode(params)}"


def _user_groups(user: dict[str, Any]) -> set[str]:
    groups: set[str] = set()
    raw = user.get("groups") or user.get("appRoles") or []
    if isinstance(raw, list):
        for item in raw:
            if isinstance(item, dict):
                name = item.get("display") or item.get("name") or item.get("value")
                if name:
                    groups.add(str(name))
            elif item:
                groups.add(str(item))
    return groups


def _compact_session_user(userinfo: dict[str, Any]) -> dict[str, Any]:
    """
    Keep session payload intentionally small.
    Starlette SessionMiddleware stores session data in the cookie itself,
    so storing full userinfo/access tokens can exceed header/cookie limits.
    """
    compact = {
        "sub": userinfo.get("sub"),
        "preferred_username": userinfo.get("preferred_username"),
        "email": userinfo.get("email"),
        "name": userinfo.get("name"),
    }
    groups = sorted(_user_groups(userinfo))
    if groups:
        compact["groups"] = groups[:50]
    return {k: v for k, v in compact.items() if v not in (None, "", [])}


def require_user(request: Request) -> dict[str, Any]:
    user = request.session.get("user")
    logger.info(
        "require_user: has_session_cookie=%s session_keys=%s has_user=%s",
        "session" in request.cookies,
        list(request.session.keys()),
        bool(user),
    )
    if not user:
        raise HTTPException(status_code=status.HTTP_401_UNAUTHORIZED, detail="Not authenticated")
    if OIDC_REQUIRED_GROUP:
        groups = _user_groups(user)
        if OIDC_REQUIRED_GROUP not in groups:
            raise HTTPException(
                status_code=status.HTTP_403_FORBIDDEN,
                detail=f"User is not in required group: {OIDC_REQUIRED_GROUP}",
            )
    return user


@app.get("/login")
def login(request: Request, next: str = "/"):
    state = os.urandom(24).hex()
    request.session["oauth_state"] = state
    request.session["post_login_redirect"] = next or "/"
    logger.info(
        "login: has_session_cookie=%s session_keys=%s next=%s state_len=%d",
        "session" in request.cookies,
        list(request.session.keys()),
        next,
        len(state),
    )
    return RedirectResponse(url=_build_authorize_url(state), status_code=302)


@app.get("/oauth2/callback")
def oauth2_callback(request: Request, code: Optional[str] = None, state: Optional[str] = None):
    expected_state = request.session.get("oauth_state")
    logger.info(
        "oauth2_callback(start): has_session_cookie=%s session_keys=%s state_present=%s expected_state_present=%s code_present=%s",
        "session" in request.cookies,
        list(request.session.keys()),
        bool(state),
        bool(expected_state),
        bool(code),
    )
    if not code or not state or not expected_state or state != expected_state:
        raise HTTPException(status_code=400, detail="Invalid OAuth callback state or missing code")

    token = _oauth_post_form(
        OIDC_TOKEN_ENDPOINT,
        {
            "grant_type": "authorization_code",
            "code": code,
            "redirect_uri": OIDC_REDIRECT_URI,
        },
    )
    access_token = token.get("access_token")
    if not access_token:
        raise HTTPException(status_code=400, detail="Token response missing access_token")

    userinfo = _oauth_get_json(OIDC_USERINFO_ENDPOINT, access_token)
    session_user = _compact_session_user(userinfo)
    request.session.clear()
    request.session["user"] = session_user
    request.session.pop("oauth_state", None)
    request.session.pop("post_login_redirect", None)
    logger.info(
        "oauth2_callback(done): userinfo_keys=%s session_user_keys=%s session_keys=%s has_user=%s",
        list(userinfo.keys()) if isinstance(userinfo, dict) else [],
        list(session_user.keys()),
        list(request.session.keys()),
        "user" in request.session,
    )
    html = """<!DOCTYPE html>
<html lang=\"en\">
<head>
  <meta charset=\"utf-8\">
  <meta http-equiv=\"refresh\" content=\"0;url=/\">
  <title>Signing in...</title>
</head>
<body>
  <p>Login successful. Redirecting...</p>
  <script>window.location.replace('/');</script>
</body>
</html>"""
    return HTMLResponse(content=html, status_code=200)


@app.get("/logout")
def logout(request: Request):
    request.session.clear()
    if OIDC_LOGOUT_ENDPOINT:
        return RedirectResponse(url=OIDC_LOGOUT_ENDPOINT, status_code=302)
    return RedirectResponse(url="/", status_code=302)


