# OCI Object Storage allowlist (comma-separated bucket names)
# Leave unset to allow all buckets (not recommended for production).
# If set, only these buckets may be referenced via *_from_bucket params.
ALLOWED_BUCKETS=my-diagrams-bucket,my-bom-bucket

# Optional: restrict to specific object-name prefixes (comma-separated)
# ALLOWED_PREFIXES=diagrams/,boms/

# Maximum BOM file upload size (bytes). Default: 25 MB
MAX_UPLOAD_BYTES_BOM=26214400

# Maximum size for resources_from_bucket object (bytes). Default: 10 MB
MAX_OBJECT_BYTES_RESOURCES=10485760

# Maximum size for text bucket objects (context, notes, questionnaire). Default: 1 MB
MAX_OBJECT_BYTES_TEXT=1048576

# OCI agent card public host (returned in /.well-known/agent-card.json)
# AGENT_PUBLIC_HOST=https://my-lb.example.com
