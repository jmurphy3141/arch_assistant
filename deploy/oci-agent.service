[Unit]
Description=OCI Drawing Agent
After=network.target

[Service]
User=opc
WorkingDirectory=/home/opc/drawing-agent
EnvironmentFile=-/home/opc/.drawing-agent.env
ExecStart=/bin/bash -lc 'set -a; [ -f /home/opc/.drawing-agent.env ] && . /home/opc/.drawing-agent.env; exec /usr/bin/python3.11 -m uvicorn drawing_agent_server:app --host 0.0.0.0 --port 8080'
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
