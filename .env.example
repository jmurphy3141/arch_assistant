# OCI Drawing Agent — environment variables
# Copy to .env and fill in the values for local development.
# On OCI Compute (production) set these via systemd EnvironmentFile or OCI Vault.
# Never commit .env to source control.

# ── Session ───────────────────────────────────────────────────────────────────
# Required. Long random string used to sign browser session cookies.
# Generate with: openssl rand -hex 32
# Must remain stable across restarts (changing it invalidates all sessions).
SESSION_SECRET=replace-with-a-long-random-secret

# ── OCI Identity Domain OIDC ──────────────────────────────────────────────────
# Leave all OIDC_* vars unset (or empty) to run without authentication.
# Auth is automatically enabled when OIDC_CLIENT_ID, OIDC_CLIENT_SECRET,
# OIDC_REDIRECT_URI, and either OIDC_ISSUER / OCI_IDENTITY_DOMAIN_URL or
# explicit endpoint overrides are present.

# Confidential application credentials from OCI Identity Domain
OIDC_CLIENT_ID=ocid1.oauth2client.oc1..example
OIDC_CLIENT_SECRET=replace-with-client-secret

# OCI Identity Domain URL. The app derives /oauth2/v1/authorize, token,
# userinfo, and userlogout endpoints from this value.
OIDC_ISSUER=https://idcs-example.identity.oraclecloud.com

# Optional explicit endpoint overrides. Usually leave these commented when using
# an OCI Identity Domain integrated/confidential application.
# OIDC_AUTHORIZATION_ENDPOINT=https://idcs-example.identity.oraclecloud.com/oauth2/v1/authorize
# OIDC_TOKEN_ENDPOINT=https://idcs-example.identity.oraclecloud.com/oauth2/v1/token
# OIDC_USERINFO_ENDPOINT=https://idcs-example.identity.oraclecloud.com/oauth2/v1/userinfo

# The callback URL registered in the Identity Domain application.
# Must exactly match — including scheme and path.
OIDC_REDIRECT_URI=https://your-hostname.example.com/oauth2/callback

# Optional: redirect here after logout (IdP single logout)
# OIDC_LOGOUT_ENDPOINT=https://idcs-example.identity.oraclecloud.com/oauth2/v1/userlogout

# Optional: require users to be a member of this Identity Domain group
# OIDC_REQUIRED_GROUP=drawing-agent-users

# Optional: OAuth scopes (default is fine for OCI Identity Domain)
# OIDC_SCOPE=openid profile email

# Optional: secure session cookies. "auto" enables Secure when OIDC_REDIRECT_URI
# starts with https://. Use false only for local HTTP development.
# SESSION_COOKIE_SECURE=auto
